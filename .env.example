# Careers application emails (Resend). Copy to .env.local and fill in.
# Without RESEND_API_KEY the form still works in dev but no emails are sent.

# Resend API key — https://resend.com/api-keys
RESEND_API_KEY=

# Sender address on a domain you've verified in Resend.
# For quick testing you may use: "JP's Hot Chicken Careers <onboarding@resend.dev>"
CAREERS_FROM_EMAIL="JP's Hot Chicken Careers <careers@jpshotchicken.com>"

# Where new applications are emailed (defaults to siteConfig.email if unset).
CAREERS_NOTIFY_EMAIL=jpshotchicken@gmail.com
